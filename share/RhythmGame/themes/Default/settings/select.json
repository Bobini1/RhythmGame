{
  "$schema": "https://raw.githubusercontent.com/Bobini1/RhythmGame/refs/heads/master/schemas/themeSettings.json",
  "items": [
    {
      "id": "sortOrder",
      "name": {
        "en": "Sort Order",
        "pl": "Kolejność sortowania"
      },
      "description": {
        "en": "The sort order of songs.",
        "pl": "Kolejność sortowania piosenek."
      },
      "type": "choice",
      "default": "title",
      "choices": [
        {
          "name": {
            "en": "Title",
            "pl": "Tytuł"
          },
          "value": "title"
        },
        {
          "name": {
            "en": "Artist",
            "pl": "Artysta"
          },
          "value": "artist"
        },
        {
          "name": {
            "en": "BPM",
            "pl": "BPM"
          },
          "value": "bpm"
        },
        {
          "name": {
            "en": "Clear",
            "pl": "Clear"
          },
          "value": "clear"
        },
        {
          "name": {
            "en": "Score",
            "pl": "Punkty"
          },
          "value": "score"
        },
        {
          "name": {
            "en": "Level",
            "pl": "Poziom"
          },
          "value": "level"
        },
        {
          "name": {
            "en": "Total",
            "pl": "total"
          },
          "value": "total"
        }
      ]
    },
    {
      "id": "keymodeFilter",
      "name": {
        "en": "Keymode Filter",
        "pl": "Filtr ilości klawiszy"
      },
      "description": {
        "en": "Filter songs by keymode.",
        "pl": "Filtrowanie piosenek według ilości klawiszy."
      },
      "type": "choice",
      "default": "7",
      "choices": [
        {
          "name": {
            "en": "5K",
            "pl": "5K"
          },
          "value": "5"
        },
        {
          "name": {
            "en": "7K",
            "pl": "7K"
          },
          "value": "7"
        },
        {
          "name": {
            "en": "Single",
            "pl": "Single"
          },
          "value": "SINGLE"
        },
        {
          "name": {
            "en": "10K",
            "pl": "10K"
          },
          "value": "10"
        },
        {
          "name": {
            "en": "14K",
            "pl": "14K"
          },
          "value": "14"
        },
        {
          "name": {
            "en": "Double",
            "pl": "Double"
          },
          "value": "DOUBLE"
        },
        {
          "name": {
            "en": "All keys",
            "pl": "Wszystkie"
          },
          "value": ""
        }
      ]
    },
    {
      "id": "densityGraphGapsEnabled",
      "name": {
        "en": "Gaps between bars in density graph",
        "pl": "Przerwy między słupkami na wykresie gęstości"
      },
      "description": {
        "en": "Add 1px gaps between bars in the density graph if possible.",
        "pl": "Dodaje 1px przerwy między słupkami na wykresie gęstości, jeśli to możliwe."
      },
      "type": "boolean",
      "default": false
    },
    {
      "id": "densityGraphBpmConnectorOpacity",
      "name": {
        "en": "Density graph BPM connector opacity",
        "pl": "Przezroczystość łączników BPM na wykresie gęstości"
      },
      "description": {
        "en": "Opacity of the gray vertical lines that connect adjacent BPM level lines.",
        "pl": "Przezroczystość szarych pionowych linii łączących poziomy BPM."
      },
      "type": "range",
      "min": 0,
      "max": 1,
      "default": 0.75
    },
    {
      "id": "rankingProvider",
      "name": {
        "en": "Ranking Provider",
        "pl": "Dostawca rankingów"
      },
      "description": {
        "en": "The provider of online rankings.",
        "pl": "Dostawca rankingów online."
      },
      "type": "choice",
      "default": "rhythmgame",
      "choices": [
        {
          "name": {
            "en": "RhythmGame",
            "pl": "RhythmGame"
          },
          "value": "rhythmgame"
        },
        {
          "name": {
            "en": "LR2IR",
            "pl": "LR2IR"
          },
          "value": "lr2ir"
        },
        {
          "name": {
            "en": "Bokutachi",
            "pl": "Bokutachi"
          },
          "value": "bokutachi"
        }
      ]
    }
  ]
}